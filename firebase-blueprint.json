{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "User profile information and reputation.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Unique identifier for the user." },
        "displayName": { "type": "string", "description": "Display name of the user." },
        "photoURL": { "type": "string", "description": "URL to the user's profile picture." },
        "reputation": { "type": "integer", "description": "User's reputation score based on activity." },
        "bio": { "type": "string", "description": "Short biography of the user." },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the profile was created." }
      },
      "required": ["uid", "displayName"]
    },
    "Post": {
      "title": "Forum Post",
      "description": "A post in the community forum.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique identifier for the post." },
        "title": { "type": "string", "description": "Title of the post." },
        "content": { "type": "string", "description": "Main content of the post." },
        "category": { "type": "string", "enum": ["olive", "citrus", "cereal", "general"], "description": "Crop category or general discussion." },
        "authorId": { "type": "string", "description": "UID of the post author." },
        "authorName": { "type": "string", "description": "Display name of the author." },
        "authorPhoto": { "type": "string", "description": "Photo URL of the author." },
        "image": { "type": "string", "description": "Optional image attached to the post." },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the post was created." },
        "likes": { "type": "integer", "description": "Number of likes on the post." }
      },
      "required": ["title", "content", "category", "authorId"]
    },
    "Comment": {
      "title": "Post Comment",
      "description": "A comment on a forum post.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique identifier for the comment." },
        "postId": { "type": "string", "description": "ID of the post this comment belongs to." },
        "content": { "type": "string", "description": "Content of the comment." },
        "authorId": { "type": "string", "description": "UID of the comment author." },
        "authorName": { "type": "string", "description": "Display name of the author." },
        "authorPhoto": { "type": "string", "description": "Photo URL of the author." },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the comment was created." }
      },
      "required": ["postId", "content", "authorId"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "Collection of user profiles."
    },
    "/posts/{postId}": {
      "schema": "Post",
      "description": "Collection of forum posts."
    },
    "/posts/{postId}/comments/{commentId}": {
      "schema": "Comment",
      "description": "Subcollection of comments for a specific post."
    }
  }
}
