rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'
          || request.auth.token.email == "youssefbenamor1234@gmail.com"
        );
    }

    function isValidUrl(url) {
      return url is string && url.matches('^https?://');
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    function isValidUser(data) {
      return hasRequiredFields(['uid', 'displayName', 'createdAt']) &&
        data.uid == request.auth.uid &&
        data.displayName is string &&
        data.displayName.size() >= 1 &&
        data.displayName.size() <= 50 &&
        (!('photoURL' in data) || isValidUrl(data.photoURL)) &&
        (!('bio' in data) || (data.bio is string && data.bio.size() <= 500)) &&
        (!('reputation' in data) || data.reputation is number) &&
        data.createdAt is timestamp;
    }

    function isValidPost(data) {
      return hasRequiredFields(['title', 'content', 'category', 'authorId', 'authorName', 'createdAt']) &&
        data.title is string &&
        data.title.size() >= 1 &&
        data.title.size() <= 200 &&
        data.content is string &&
        data.content.size() >= 1 &&
        data.content.size() <= 5000 &&
        data.category in ['olive', 'citrus', 'cereal', 'general'] &&
        data.authorId == request.auth.uid &&
        data.authorName is string &&
        data.authorName.size() <= 50 &&
        (!('authorPhoto' in data) || isValidUrl(data.authorPhoto)) &&
        data.createdAt is timestamp &&
        (!('likes' in data) || data.likes is number);
    }

    function isValidComment(data) {
      return hasRequiredFields(['postId', 'content', 'authorId', 'authorName', 'createdAt']) &&
        data.postId is string &&
        data.content is string &&
        data.content.size() >= 1 &&
        data.content.size() <= 1000 &&
        data.authorId == request.auth.uid &&
        data.authorName is string &&
        data.authorName.size() <= 50 &&
        (!('authorPhoto' in data) || isValidUrl(data.authorPhoto)) &&
        data.createdAt is timestamp;
    }

    // ================= USERS =================
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      allow update: if (isOwner(userId) && isValidUser(request.resource.data)) || isAdmin();
      allow delete: if isAdmin();
    }

    // ================= POSTS =================
    match /posts/{postId} {

      // 🔓 Public read (even without login)
      allow read: if true;

      allow create: if isAuthenticated() && isValidPost(request.resource.data);

      allow update: if isAuthenticated() && (
        isAdmin() ||
        (isOwner(resource.data.authorId) && isValidPost(request.resource.data))
      );

      allow delete: if isOwner(resource.data.authorId) || isAdmin();

      // ================= COMMENTS =================
      match /comments/{commentId} {

        // 🔓 Public read
        allow read: if true;

        allow create: if isAuthenticated() && isValidComment(request.resource.data);

        allow update: if isAdmin() ||
          (isOwner(resource.data.authorId) && isValidComment(request.resource.data));

        allow delete: if isOwner(resource.data.authorId) || isAdmin();
      }
    }

    // ================= DEFAULT DENY =================
    match /{document=**} {
      allow read, write: if false;
    }
  }
}